// ============= SETTINGS SCREEN =============

class SettingsScreen extends StatefulWidget {
  final String currency;

  const SettingsScreen({Key? key, required this.currency}) : super(key: key);

  @override
  State<SettingsScreen> createState() => _SettingsScreenState();
}

class _SettingsScreenState extends State<SettingsScreen> {
  late String _currency;
  ThemeMode _themeMode = ThemeMode.light;

  @override
  void initState() {
    super.initState();
    _currency = widget.currency;
    _load();
  }

  Future<void> _load() async {
    final prefs = await SharedPreferences.getInstance();
    setState(() {
      _themeMode = ThemeMode.values[prefs.getInt('themeMode') ?? 0];
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text('Settings')),
      body: ListView(
        padding: const EdgeInsets.all(16),
        children: [
          ListTile(
            title: const Text('Currency'),
            subtitle: Text(_currency),
            trailing: const Icon(Icons.chevron_right),
            onTap: () async {
              final result = await showDialog<String>(
                context: context,
                builder: (context) => SimpleDialog(
                  title: const Text('Select Currency'),
                  children: ['₹', '\$', '€', '£', '¥']
                      .map(
                        (c) => SimpleDialogOption(
                          onPressed: () => Navigator.pop(context, c),
                          child: Text(c),
                        ),
                      )
                      .toList(),
                ),
              );
              if (result != null) {
                final prefs = await SharedPreferences.getInstance();
                await prefs.setString('currency', result);
                setState(() => _currency = result);
              }
            },
          ),
          const SizedBox(height: 12),
          ListTile(
            title: const Text('Theme'),
            subtitle: Text(
              _themeMode == ThemeMode.light
                  ? 'Light'
                  : _themeMode == ThemeMode.dark
                  ? 'Dark'
                  : 'System',
            ),
            trailing: const Icon(Icons.chevron_right),
            onTap: () async {
              final result = await showDialog<ThemeMode>(
                context: context,
                builder: (context) => SimpleDialog(
                  title: const Text('Select Theme'),
                  children: [
                    SimpleDialogOption(
                      onPressed: () => Navigator.pop(context, ThemeMode.light),
                      child: const Text('Light'),
                    ),
                    SimpleDialogOption(
                      onPressed: () => Navigator.pop(context, ThemeMode.dark),
                      child: const Text('Dark'),
                    ),
                    SimpleDialogOption(
                      onPressed: () => Navigator.pop(context, ThemeMode.system),
                      child: const Text('System'),
                    ),
                  ],
                ),
              );
              if (result != null) {
                final prefs = await SharedPreferences.getInstance();
                await prefs.setInt('themeMode', result.index);
                setState(() => _themeMode = result);
              }
            },
          ),
          const SizedBox(height: 12),
          ListTile(
            title: const Text('Delete Data by Month'),
            trailing: const Icon(Icons.delete_sweep),
            onTap: () async {
              final date = await showDatePicker(
                context: context,
                initialDate: DateTime.now(),
                firstDate: DateTime(2020),
                lastDate: DateTime(2030),
              );
              if (date != null) {
                final confirm = await showDialog<bool>(
                  context: context,
                  builder: (context) => AlertDialog(
                    title: const Text('Delete Data'),
                    content: Text(
                      'Delete all transactions from ${DateFormat('MMMM yyyy').format(date)}?',
                    ),
                    actions: [
                      TextButton(
                        onPressed: () => Navigator.pop(context, false),
                        child: const Text('Cancel'),
                      ),
                      TextButton(
                        onPressed: () => Navigator.pop(context, true),
                        child: const Text(
                          'Delete',
                          style: TextStyle(color: Colors.red),
                        ),
                      ),
                    ],
                  ),
                );
                if (confirm == true) {
                  final transactions = await DataManager.getTransactions();
                  transactions.removeWhere(
                    (t) =>
                        t.date.year == date.year && t.date.month == date.month,
                  );
                  await DataManager.saveTransactions(transactions);
                  if (mounted) {
                    ScaffoldMessenger.of(context).showSnackBar(
                      const SnackBar(
                        content: Text('Data deleted successfully'),
                      ),
                    );
                  }
                }
              }
            },
          ),
        ],
      ),
    );
  }
}

// ============= IMPORT/EXPORT SCREEN =============

class ImportExportScreen extends StatelessWidget {
  final List<Transaction> transactions;
  final String currency;

  const ImportExportScreen({
    Key? key,
